# Backend environment. Copy to .env and fill in. NEVER commit the real .env.

# Optional — only needed for Claude-powered features (resume tailoring/ATS).
ANTHROPIC_API_KEY=

# SQLite location. Local default is fine; on a server point at a persistent disk:
#   DATABASE_URL=sqlite:////data/jobsense.db
DATABASE_URL=sqlite:///./jobsense.db

# Comma-separated production frontend origins for CORS (only if frontend is hosted
# separately from the backend). Not needed when one box serves both.
#   FRONTEND_ORIGINS=https://your-app.vercel.app
FRONTEND_ORIGINS=
